# Do not commit `.env.local` to the repository.
# Do not use the Supabase service role key in frontend code.
# `NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY` is the public/publishable key for the Supabase project.
# For local development, copy the generated local value from `npx supabase status`.
# Supabase public keys do not replace Row Level Security (RLS).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
